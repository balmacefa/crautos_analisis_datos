FROM typesense/typesense:26.0

# Install curl for health checks
RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

# Create a directory for the config and logs
# We use /var/log/typesense for logs
RUN mkdir -p /etc/typesense /var/log/typesense /data

COPY config.ini /etc/typesense/config.ini

EXPOSE 8108

# Data Persistence
VOLUME ["/data"]

# Note: Inheriting ENTRYPOINT from the base image. 
# We'll override the CMD in docker-compose to point to our config.ini.
