# ──────────────────────────────────────────────
# Crautos Scraper — Environment Variables
# Copy this file to .env and adjust values
# ──────────────────────────────────────────────

# SQLite database path (inside the container; /app/data is mounted to ./data on host)
SCRAPER_DB_PATH=/app/data/crautos.db

# Run browser in headless mode (true for Docker, false for local debugging)
SCRAPER_HEADLESS=true

# Adaptive concurrency settings for 02_scraper_car_details
SCRAPER_INITIAL_CONCURRENCY=3
SCRAPER_MIN_CONCURRENCY=1
SCRAPER_MAX_CONCURRENCY=10
